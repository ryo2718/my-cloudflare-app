# Example env file. Copy to `.env.local` (gitignored) and fill in real values.
# Vite exposes only VITE_-prefixed vars to the client bundle.

# Flop tree データの R2 配信元 (base URL は config まで含む)。
# 例: https://pub-xxxxxxxx.r2.dev/data/flop/v1/cash_100bb_6max_nl500_2.5x
VITE_FLOP_DATA_BASE_URL=https://pub-xxxxxxxx.r2.dev/data/flop/v1/cash_100bb_6max_nl500_2.5x

# Preflop range データの R2 配信元 (base URL は /v1 まで。config は app 側で付与)。
# fetch URL: ${VITE_PREFLOP_DATA_BASE_URL}/<config>/by_chain/<chain>.json
# 例: https://pub-xxxxxxxx.r2.dev/data/preflop/v1
# Dev では Vite proxy 経由で /r2-preflop を指定 (.env.development.local)。
# Phase 1 ではまだ app から参照されない (Phase 2 でローダ配線)。
VITE_PREFLOP_DATA_BASE_URL=https://pub-xxxxxxxx.r2.dev/data/preflop/v1
