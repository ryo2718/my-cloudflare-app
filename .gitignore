# --- Logs ---
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Wrangler (Pages Functions / D1 local state) ---
.wrangler/

# --- Build artifacts ---
node_modules
dist
dist-ssr
.vite
*.tsbuildinfo

# --- Environment / secrets ---
*.local
.env
.env.*
!.env.example

# --- Editor / OS ---
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- Claude Code project state (machine-local) ---
.claude/

# --- Local backups (not deployed, not tracked) ---
# 主バックアップは public/ の外 (/backups/) に配置されているのでビルドにも含まれない。
# 詳細は backups/README.md を参照。
/backups/

# 万一 public/ 配下に再配置されてしまった場合の防御 (Vite が dist/ にコピーするのを
# 防ぐため、必ず public/ の外に置くこと):
public/data/preflop/*/before_sparse_*/
public/data/preflop/*/before_swap_*/
public/data/preflop/*/before_final_batch_*/
public/data/preflop/*/B_filled/
public/data/preflop/*/original_backup/
public/data/preflop/*/repaired/

# --- Flop strategy data (R2 hosted, not committed) ---
# Flop tree データ (data/cash_<config>/) は 1.6 GB / 2,686 ファイル と巨大なため Cloudflare R2 から
# 配信する。ローカル作業コピーは git に含めない。R2 アップロード手順は docs/FLOP_STRATEGY_TAB.md §4.1 参照。
/data/cash_*/
.env.production

# --- Flop training データ ステージング (webscraping から複製、後で加工して使う) ---
# public 外・非デプロイ。20MB のため git には含めない (誤コミット防止)。
/flop_data/

# --- Preflop range data (R2 hosted, not committed) ---
# 新 preflop range の生スクレイプ出力 (preflop_ranges/<config>/by_chain/) は 772 MB と巨大。
# scripts/build-preflop-data.cjs で dist-preflop-data/ に変換し (~224 MB / ~24 MB gzip)、
# flop と同様 Cloudflare R2 から配信する。どちらも git には含めない。
# R2 アップロード手順は docs/PREFLOP_STRATEGY_TAB.md 参照。
/preflop_ranges/
/dist-preflop-data/
